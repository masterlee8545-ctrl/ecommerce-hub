# ============================================================
# BUYWISE 이커머스 통합관리 시스템 — 환경변수 템플릿
# ============================================================
# 이 파일을 .env.local로 복사한 후 실제 값을 채우세요.
# .env.local은 절대 git에 커밋하지 마세요. (CLAUDE.md §1 P-7)
# ============================================================

# ───────────────────────────────────────────────────────────
# 1. Database (Supabase)
# ───────────────────────────────────────────────────────────
# Supabase 프로젝트 → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase 프로젝트 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# ⚠ SERVICE_ROLE_KEY는 서버에서만 사용. 클라이언트 노출 절대 금지.

# ───────────────────────────────────────────────────────────
# 2. NextAuth.js v5
# ───────────────────────────────────────────────────────────
# 32자 이상 랜덤 문자열 (`openssl rand -base64 32`)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3002

# ───────────────────────────────────────────────────────────
# 3. BW Rank API (자체 인프라, 인증 없음 - ADR-006)
# ───────────────────────────────────────────────────────────
# ⚠ 클라이언트 노출 금지. 서버 사이드 프록시 (/api/bwrank/*) 통해서만 사용.
BWRANK_BASE_URL=https://api.bw-rank.kr

# ───────────────────────────────────────────────────────────
# 4. Coupang Review API (1페이지 36개 리뷰 수집 - ADR-008)
# ───────────────────────────────────────────────────────────
COUPANG_REVIEW_API_URL=https://coupang-api.zpost.shop

# ───────────────────────────────────────────────────────────
# 5. Anthropic Claude API (마진 추정 - ADR-007)
# ───────────────────────────────────────────────────────────
# Anthropic Console → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-opus-4-5

# ───────────────────────────────────────────────────────────
# 6. Naver API (Phase 2)
# ───────────────────────────────────────────────────────────
# 네이버 개발자 센터 → 애플리케이션 등록
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=

# ───────────────────────────────────────────────────────────
# 6.5 InfoHub MCP (형제 프로젝트 - ADR-011)
# ───────────────────────────────────────────────────────────
# Phase 1 MVP는 Claude Code 세션에서 mcp__infohub__* 도구로 직접 호출 (모드 A)
# 아래 변수들은 Phase 2 모드 B (Next.js 앱이 InfoHub REST API 직접 호출) 도입 시 필요
# 자세한 내용: docs/INFOHUB_INTEGRATION.md, docs/ADR.md ADR-011
#
# InfoHub 앱 URL (출처: 정보취합-2/mcp-server/index.ts)
INFOHUB_URL=https://infohub-app-bwzkr.vercel.app
# InfoHub 인증 토큰 (Supabase JWT)
# - 수동 발급: InfoHub 웹앱 로그인 → Cookies → sb-access-token 복사
# - 자동 갱신: 아래 SUPABASE_SERVICE_ROLE_KEY로 magic link 통해 자동 발급 가능
INFOHUB_AUTH_TOKEN=
# InfoHub Supabase 프로젝트 (자동 토큰 갱신 사용 시)
INFOHUB_SUPABASE_URL=https://mxmfbcjgfbxicmeyjqow.supabase.co
INFOHUB_SUPABASE_SERVICE_ROLE_KEY=
INFOHUB_USER_EMAIL=ecommerce-hub@buywise.dev
# InfoHub 호출 타임아웃 (collect는 최대 2분 소요 가능)
INFOHUB_TIMEOUT_MS=120000
# InfoHub 응답 캐시 TTL (6시간 = 21600초, ADR-011)
INFOHUB_CACHE_TTL_SEC=21600
# ⚠ InfoHub는 형제 프로젝트(인프라)다. 응답 스키마 변경 시 ecommerce-hub 깨짐.
# ⚠ InfoHub에서 가져온 모든 데이터는 🟡 estimated 마킹 강제 (ADR-007 + ADR-011)

# ───────────────────────────────────────────────────────────
# 7. Cron Secret (Vercel Cron 보안)
# ───────────────────────────────────────────────────────────
# 32자 이상 랜덤 문자열
CRON_SECRET=

# ───────────────────────────────────────────────────────────
# 8. 환율 API (선택)
# ───────────────────────────────────────────────────────────
# 한국수출입은행 환율 API
EXIM_API_KEY=

# ───────────────────────────────────────────────────────────
# 9. 개발 모드 설정
# ───────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
